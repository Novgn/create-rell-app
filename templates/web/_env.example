# {{projectName}} — environment variables template
#
# Copy this file to `.env.local` at the project root, then fill in the
# values before running the app. Never commit real credentials — the
# generated .gitignore already excludes `.env*` (except this example file).

# Clerk — get these from https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk Billing webhook signing secret — required by the webhook route at
# `app/api/webhooks/clerk-billing/route.ts`. Configure the webhook in your
# Clerk Dashboard at https://dashboard.clerk.com/last-active?path=webhooks
# and paste the Signing Secret here so the app can verify incoming events.
CLERK_BILLING_WEBHOOK_SIGNING_SECRET=

# Supabase — get these from https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Drizzle / direct Postgres connection (Supabase direct-connection string)
# DATABASE_URL=postgresql://postgres:[password]@[project-ref].supabase.co:5432/postgres
