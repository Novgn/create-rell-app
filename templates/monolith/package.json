{
  "name": "{{projectName}}",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["apps/*", "packages/*"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "{{pmRunCmd}} --prefix apps/web dev",
    "dev:mobile": "{{pmRunCmd}} --prefix apps/mobile start",
    "build:web": "{{pmRunCmd}} --prefix apps/web build",
    "typecheck": "tsc -b apps/web apps/mobile packages/shared --noEmit",
    "lint": "{{pmRunCmd}} --prefix apps/web lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:generate": "{{pmRunCmd}} --prefix packages/shared db:generate",
    "db:migrate": "{{pmRunCmd}} --prefix packages/shared db:migrate",
    "db:push": "{{pmRunCmd}} --prefix packages/shared db:push",
    "db:studio": "{{pmRunCmd}} --prefix packages/shared db:studio"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "10.2.0",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "16.2.6",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2
  },
  "lint-staged": {
    "*.{ts,tsx}": ["prettier --write"],
    "*.{js,jsx,mjs,cjs,json,css,md}": ["prettier --write"]
  }
}
