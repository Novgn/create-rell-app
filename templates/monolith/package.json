{
  "name": "{{projectName}}",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["apps/*", "packages/*"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "cd apps/web && {{pmRunCmd}} dev",
    "dev:mobile": "cd apps/mobile && {{pmRunCmd}} start",
    "build:web": "cd apps/web && {{pmRunCmd}} build",
    "typecheck": "tsc -b apps/web apps/mobile packages/shared --noEmit",
    "lint": "cd apps/web && {{pmRunCmd}} lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:generate": "cd packages/shared && {{pmRunCmd}} db:generate",
    "db:migrate": "cd packages/shared && {{pmRunCmd}} db:migrate",
    "db:push": "cd packages/shared && {{pmRunCmd}} db:push",
    "db:studio": "cd packages/shared && {{pmRunCmd}} db:studio",
    "check-env": "cd apps/web && {{pmRunCmd}} check-env && cd ../mobile && {{pmRunCmd}} check-env"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "16.2.6",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "tabWidth": 2
  },
  "lint-staged": {
    "*.{ts,tsx}": ["prettier --write"],
    "*.{js,jsx,mjs,cjs,json,css,md}": ["prettier --write"]
  }
}
